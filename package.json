{
  "name": "sm-codex-rebirth",
  "version": "1.0.0",
  "description": "Sovereign Mesh Codex - Rebirth",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "tsx watch server/server.ts",
    "client": "vite",
    "build": "tsc && vite build",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.1.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
