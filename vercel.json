{
  "version": 2,
  "builds": [
    {
      "src": "server/serverless.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["shared/**", "knowledge/**"] }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client",
        "workingDirectory": "client"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/server/serverless.ts" },
    { "src": "/(.*)", "dest": "/client/index.html" }
  ]
}